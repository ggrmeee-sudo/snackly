# Скопируйте в файл .env в КОРНЕ репозитория (рядом с package.json).
# Файл .env в git не коммитится.

TELEGRAM_BOT_TOKEN=
# Опционально: числовой chat id (@userinfobot) — пересылка текстов гостей админу
TELEGRAM_ADMIN_CHAT_ID=

# Картинки бота: backend/assets/telegram-bot/
#   bot-profile-logo.png — аватар при npm run bot:telegram
#   start-welcome.png    — фото к ответу на /start
