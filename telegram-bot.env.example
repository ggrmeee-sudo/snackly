# Скопируйте в файл .env в КОРНЕ репозитория (рядом с package.json).
# Файл .env не коммитится в Git.

TELEGRAM_BOT_TOKEN=
# Опционально: ваш числовой id (узнайте у @userinfobot) — тогда текст от гостей будет приходить вам
TELEGRAM_ADMIN_CHAT_ID=

# Картинки бота (в репозитории): backend/assets/telegram-bot/
#   bot-profile-logo.png — аватар при запуске npm run bot:telegram
#   start-welcome.png    — фото к ответу на /start
