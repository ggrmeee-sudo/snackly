{
  "name": "snacks-site",
  "private": true,
  "description": "Snackly: клиент (Vite) + API (Express)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node backend/src/server.js",
    "dev:client": "npm run dev --prefix frontend",
    "dev:full": "concurrently -n api,client -c blue,green \"npm run dev\" \"npm run dev:client\"",
    "build": "npm install --prefix frontend && npm run build:client",
    "build:client": "npm run build --prefix frontend",
    "start": "node backend/src/server.js",
    "bot:telegram": "node backend/src/telegram-feedback-bot.js",
    "process-logo": "node tools/process_logo.js"
  },
  "dependencies": {
    "express": "^4.22.1",
    "jimp": "^0.22.12"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
